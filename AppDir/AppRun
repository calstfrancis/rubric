#!/bin/sh
# Rubric launcher — runs from extracted payload directory
HERE="${APPDIR:-$(dirname "$(readlink -f "$0")")}"

_error() {
    notify-send -a "Rubric" -i dialog-error "Rubric failed to start" "$1" 2>/dev/null \
        || zenity --error --title="Rubric" --text="$1" 2>/dev/null \
        || echo "Rubric: $1" >&2
    exit 1
}

command -v python3 >/dev/null 2>&1 \
    || _error "Python 3 was not found. Install python3 and try again."

python3 -c "import gi; gi.require_version('Gtk','4.0'); gi.require_version('Adw','1')" 2>/dev/null \
    || _error "GTK4 and libadwaita Python bindings are required.\nInstall: sudo zypper install python3-gobject typelib-1_0-Adw-1"

exec python3 "$HERE/usr/share/rubric/rubric.py" "$@"
