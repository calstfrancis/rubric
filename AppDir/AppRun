#!/bin/sh
# Rubric AppImage — installs on first run, then launches.
# Re-run a newer AppImage to update in place.

HERE="${APPDIR:-$(dirname "$(readlink -f "$0")")}"
SRC="$HERE/usr/share/rubric"

INSTALL_DIR="$HOME/.local/share/rubric"
BIN_DIR="$HOME/.local/bin"
DESKTOP_DIR="$HOME/.local/share/applications"
ICON_BASE="$HOME/.local/share/icons/hicolor"

_error() {
    notify-send -a "Rubric" -i dialog-error "Rubric failed to start" "$1" 2>/dev/null \
        || zenity --error --title="Rubric" --text="$1" 2>/dev/null \
        || echo "Rubric: $1" >&2
    exit 1
}

# ── Dependency check ──────────────────────────────────────────────────────────
command -v python3 >/dev/null 2>&1 \
    || _error "Python 3 was not found. Install python3 and try again."

python3 -c "import gi; gi.require_version('Gtk','4.0'); gi.require_version('Adw','1')" 2>/dev/null \
    || _error "GTK4 and libadwaita Python bindings are required.\nInstall: sudo zypper install python3-gobject typelib-1_0-Adw-1"

# ── Install / update if needed ────────────────────────────────────────────────
THIS_VER=$(python3 -c "import re; print(re.search(r\"APP_VERSION\s*=\s*[\\\"'](.*?)[\\\"']\", open('$SRC/rubric.py').read()).group(1))" 2>/dev/null)
INST_VER=$(python3 -c "import re; print(re.search(r\"APP_VERSION\s*=\s*[\\\"'](.*?)[\\\"']\", open('$INSTALL_DIR/rubric.py').read()).group(1))" 2>/dev/null || echo "")

if [ "$THIS_VER" != "$INST_VER" ]; then
    echo "Installing Rubric $THIS_VER..."

    # App files
    mkdir -p "$INSTALL_DIR"
    cp -r "$SRC/." "$INSTALL_DIR/"

    # Terminal launcher
    mkdir -p "$BIN_DIR"
    printf '#!/bin/sh\nexec python3 "%s/rubric.py" "$@"\n' "$INSTALL_DIR" > "$BIN_DIR/rubric"
    chmod +x "$BIN_DIR/rubric"

    # Desktop entry
    mkdir -p "$DESKTOP_DIR"
    cat > "$DESKTOP_DIR/io.github.calstfrancis.rubric.desktop" << EOF
[Desktop Entry]
Name=Rubric
GenericName=Worship Service Planner
Comment=Plan worship service orders with RCL readings
Exec=$BIN_DIR/rubric %f
Icon=io.github.calstfrancis.rubric
Terminal=false
Type=Application
Categories=Office;Education;
Keywords=worship;liturgy;service;church;UCC;lectionary;RCL;
StartupNotify=true
StartupWMClass=rubric
MimeType=application/x-liturgy;
EOF

    # Icons
    mkdir -p "$ICON_BASE/scalable/apps" "$ICON_BASE/symbolic/apps"
    cp "$HERE/usr/share/icons/hicolor/scalable/apps/io.github.calstfrancis.rubric.svg" \
       "$ICON_BASE/scalable/apps/io.github.calstfrancis.rubric.svg"
    cp "$HERE/usr/share/icons/hicolor/symbolic/apps/io.github.calstfrancis.rubric-symbolic.svg" \
       "$ICON_BASE/symbolic/apps/io.github.calstfrancis.rubric-symbolic.svg"

    # MIME type
    mkdir -p "$HOME/.local/share/mime/packages"
    cat > "$HOME/.local/share/mime/packages/rubric.xml" << 'MIMEEOF'
<?xml version="1.0" encoding="UTF-8"?>
<mime-info xmlns="http://www.freedesktop.org/standards/shared-mime-info">
  <mime-type type="application/x-liturgy">
    <comment>Rubric service file</comment>
    <glob pattern="*.liturgy"/>
  </mime-type>
</mime-info>
MIMEEOF

    # Update caches
    update-mime-database "$HOME/.local/share/mime" 2>/dev/null || true
    gtk4-update-icon-cache -f -t "$ICON_BASE" 2>/dev/null \
        || gtk-update-icon-cache -f -t "$ICON_BASE" 2>/dev/null || true
    update-desktop-database "$DESKTOP_DIR" 2>/dev/null || true

    echo "Rubric $THIS_VER installed."
fi

# ── Launch ────────────────────────────────────────────────────────────────────
exec python3 "$INSTALL_DIR/rubric.py" "$@"
